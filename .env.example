# Railway Postgres connection URL
DATABASE_URL=postgresql://postgres:password@host.railway.app:5432/railway
# Optional: set false if your DB/proxy does not support SSL
DATABASE_SSL=false

# Admin auth session signing secret (set a long random string in production)
ADMIN_SESSION_SECRET=replace-with-long-random-secret

# Seeder variables for `npm run seed:admin`
ADMIN_SEED_EMAIL=admin@brandscafe.com
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_NAME=Admin User
